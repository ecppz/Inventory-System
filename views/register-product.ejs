<%- include('layouts/header') %>
    <main>
        <div class="container">
            <div class="card-left">
                <div class="card-form">
                    <form id="add-form" action="/register-product" method="post" enctype="multipart/form-data">
                        <h1>Registrar item</h1>
                        <div class="sections">
                            <label class="form-label" for="codigo">Codigo</label>
                            <input c    lass="form-control" id="codigo" name="codigo" type="text"
                                placeholder="Codigo del articulo" required>
                        </div>

                        <div class="sections">
                            <label class="form-label" for="articulo">Articulo</label>
                            <input class="form-control" id="articulo" name="articulo" type="text"
                                placeholder="Nombre del articulo" required>
                        </div>

                        <div class="sections">
                            <label class="form-label" for="descripcion">Descripcion</label>
                            <textarea class="form-control" id="descripcion" name="descripcion"
                                placeholder="Descripcion del producto" required></textarea>
                        </div>

                        <div class="sections">
                            <label class="form-label" for="stock">Stock</label>
                            <input class="form-control" id="stock" name="stock" type="number"
                                placeholder="Cantidad disponible en almacen" required>
                        </div>

                        <div class="sections">
                            <label class="form-label" for="precio">Precio</label>
                            <input class="form-control" id="precio" name="precio" type="number"
                                placeholder="Precio del articulo" required>
                        </div>

                        <div class="sections">
                            <label for="formFile" class="file-upload">Subir imagen</label>
                            <input class="form-control" id="formFile" name="image" type="file">
                        </div>

                        <div class="sections">
                            <button type="submit">Enviar<i class="fa-solid fa-arrow-right"></i></button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card-right"></div>
        </div>
    </main>
    <%- include('layouts/footer') %>