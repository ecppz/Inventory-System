<%- include('../layouts/header-anonymous') %>

  <main>
    <div class="container-login">
      <div class="card-login">
        <h1>Iniciar sesión</h1>

        <% if (message) { %>
          <div class="alert-message <%= message.type %>">
            <%= message.alert %>
          </div>
          <% } %>

            <form action="/login" method="POST" class="form-login">
              <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="ejemplo@mail.com" required>
              </div>

              <div class="form-group">
                <label>Contraseña</label>
                <input type="password" name="password" placeholder="********" required>
              </div>

              <button type="submit">Iniciar sesión <i class="fa-solid fa-right-to-bracket"></i></button>
            </form>

            <p class="redirect-text">¿No tienes cuenta? <a href="/register">Registrarse</a></p>
      </div>
    </div>
  </main>

  <%- include('../layouts/footer') %>